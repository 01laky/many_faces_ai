# Development Environment Variables for AI Demo gRPC Server
# Copy this file to .env and update values as needed
# Note: Environment variables are typically set in docker-compose.dev.yml

# gRPC Server Port
# Default: 50051
PORT=50051

# Inference backend:
# ai-demo-dev stays the gRPC adapter; generation runs via Ollama HTTP API.

# Recommended Windows RTX 3050 4GB + 10GB RAM + 8 CPU threads experiment:
OLLAMA_BASE_URL=http://host.docker.internal:11434
OLLAMA_MODEL=qwen2.5:7b-instruct-q4_K_M
OLLAMA_NUM_CTX=4096
OLLAMA_NUM_THREAD=8
OLLAMA_NUM_GPU=20
OLLAMA_NUM_BATCH=128
OLLAMA_KEEP_ALIVE=30m
OLLAMA_TEMPERATURE=0.35
OLLAMA_TOP_P=0.9
OLLAMA_TOP_K=40
OLLAMA_REPEAT_PENALTY=1.15
