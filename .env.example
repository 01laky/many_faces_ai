# many_faces_ai — environment template (copy to .env.local; never commit secrets)

# --- gRPC server ---
PORT=50051

# Shared secret for backend → worker gRPC (metadata x-ai-worker-token)
# Leave empty in local dev to disable auth interceptor.
AI_WORKER_EXPECTED_TOKEN=

# Hardened profile: require token (+ TLS or MFAI_ALLOW_INSECURE_GRPC)
MFAI_REQUIRE_WORKER_AUTH=0
MFAI_HARDENED_PROFILE=0
MFAI_ALLOW_INSECURE_GRPC=1

# Optional gRPC TLS server credentials (PEM files inside container)
# GRPC_TLS_CERT_FILE=/certs/server.pem
# GRPC_TLS_KEY_FILE=/certs/server-key.pem

# Require token on HealthCheck (default: public probe)
MFAI_HEALTHCHECK_REQUIRES_TOKEN=0

# --- Ollama ---
OLLAMA_BASE_URL=http://host.docker.internal:11434
OLLAMA_MODEL=qwen2.5:7b-instruct-q4_K_M
OLLAMA_TIMEOUT_SECONDS=300
# 7B-perf O1: keep the model resident (the worker also sends keep_alive=-1 per request).
OLLAMA_KEEP_ALIVE=-1
# 7B-perf O19: optional CPU-resident helper model (small; advisory routing/gating). Empty ⇒ disabled.
# Pulled at startup if absent (scripts/pull_helper_model.py); run num_gpu=0 (CPU/RAM) alongside the GPU 7B.
# OLLAMA_MODEL_HELPER=qwen2.5:3b-instruct-q4_K_M
# Per-model GPU offload: GPU layers for the helper model (0 = CPU-only, the default even when unset, so the
# helper stays off the GPU). The main model uses OLLAMA_NUM_GPU; unset ⇒ Ollama auto-offloads the max that fits.
# OLLAMA_NUM_GPU_HELPER=0

# --- Outbound HTTP (FetchPublicStats) ---
# In hardened profile, HTTP is HTTPS-only except loopback when explicitly allowed:
# MFAI_ALLOW_HTTP_LOOPBACK=1

# --- RPC abuse limits ---
# AIH1_RPC_RATE_PER_MIN=60

# --- Capability roadmap v0.9.0 (AI-UP1…UP20) ---
# MFAI_LLM_MODERATION=0
# OLLAMA_MODEL_CHAT=
# OLLAMA_MODEL_MODERATION=
# Skill-router embeddings. Unset ⇒ resolve_model falls back to OLLAMA_MODEL (the chat 7B), which Ollama
# rejects for embeddings ("does not support embeddings"). Pull once: `ollama pull nomic-embed-text`.
# OLLAMA_MODEL_EMBED=nomic-embed-text
# OLLAMA_CB_FAILURE_THRESHOLD=5
# OLLAMA_CB_OPEN_SECONDS=60
# OLLAMA_CB_DISABLED=0
# AUTO_APPROVE_MIN_CONFIDENCE=0.95
# MODERATION_RULES_AUTO_THRESHOLD=0.88
# SEARCH_WORKER_GRPC_ADDRESS=
# OLLAMA_EMBED_MAX_BATCH=8
# OLLAMA_EMBED_MAX_CHARS=8000

# --- Model preload ---
MFAI_PRELOAD_MODEL=1

# --- Debug logging (dev only) ---
# AIH1_LOG_DEBUG=1
