# many_faces_ai — environment template (copy to .env.local; never commit secrets)

# --- gRPC server ---
PORT=50051

# Shared secret for backend → worker gRPC (metadata x-ai-worker-token)
# Leave empty in local dev to disable auth interceptor.
AI_WORKER_EXPECTED_TOKEN=

# Hardened profile: require token (+ TLS or MFAI_ALLOW_INSECURE_GRPC)
MFAI_REQUIRE_WORKER_AUTH=0
MFAI_HARDENED_PROFILE=0
MFAI_ALLOW_INSECURE_GRPC=1

# Optional gRPC TLS server credentials (PEM files inside container)
# GRPC_TLS_CERT_FILE=/certs/server.pem
# GRPC_TLS_KEY_FILE=/certs/server-key.pem

# Require token on HealthCheck (default: public probe)
MFAI_HEALTHCHECK_REQUIRES_TOKEN=0

# --- Ollama ---
OLLAMA_BASE_URL=http://host.docker.internal:11434
OLLAMA_MODEL=qwen2.5:7b-instruct-q4_K_M
OLLAMA_TIMEOUT_SECONDS=300

# --- Outbound HTTP (FetchPublicStats) ---
# In hardened profile, HTTP is HTTPS-only except loopback when explicitly allowed:
# MFAI_ALLOW_HTTP_LOOPBACK=1

# --- RPC abuse limits ---
# AIH1_RPC_RATE_PER_MIN=60

# --- Model preload ---
MFAI_PRELOAD_MODEL=1

# --- Debug logging (dev only) ---
# AIH1_LOG_DEBUG=1
