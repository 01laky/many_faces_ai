# Dockerfile.dev - Development Docker image for AI Demo gRPC server
# This image includes Python, gRPC dependencies, and development tools

FROM python:3.11-slim

# Set working directory
WORKDIR /app

# Install system dependencies
RUN apt-get update && apt-get install -y \
    gcc \
    && rm -rf /var/lib/apt/lists/*

# Copy requirements first for better Docker layer caching
COPY requirements.txt .

# Install Python dependencies
RUN pip install --no-cache-dir -r requirements.txt

# Copy proto files
COPY proto/ proto/

# Generate Python gRPC code from proto files
# This creates proto/health_pb2.py and proto/health_pb2_grpc.py
# Output is set to proto/ directory to match the import path in server.py
RUN python3 -m grpc_tools.protoc \
    --python_out=proto \
    --grpc_python_out=proto \
    --proto_path=proto \
    proto/health.proto

# Copy application code
COPY server.py .

# Create proto/__init__.py if it doesn't exist (allows proto to be imported as package)
RUN touch proto/__init__.py || true

# Make server.py executable
RUN chmod +x server.py

# Expose gRPC port (default 50051)
EXPOSE 50051

# Set default environment variables
ENV PORT=50051

# Run the server
# Use python -m to run as module, which ensures proper path handling
CMD ["python", "-m", "server"]
