# Dockerfile.dev - Development Docker image for AI Demo gRPC server
# This image includes Python, gRPC dependencies, and development tools

FROM python:3.11-slim

# Set working directory
WORKDIR /app

# Copy requirements first for better Docker layer caching
COPY requirements.txt .

# Default CPU wheels; compose build-arg PYTORCH_INDEX=cu124 for NVIDIA GPU.
ARG PYTORCH_INDEX=https://download.pytorch.org/whl/cpu
RUN pip install --no-cache-dir torch --index-url ${PYTORCH_INDEX}
RUN pip install --no-cache-dir -r requirements.txt

# Nested many_faces_proto submodule (Strategy B) — copy into image for protoc
COPY many_faces_proto /mfproto

# Generate Python gRPC code into proto/ (matches server.py import layout)
RUN mkdir -p proto \
    && python3 -m grpc_tools.protoc \
    --python_out=proto \
    --grpc_python_out=proto \
    --proto_path=/mfproto/proto \
    health.proto

# Fix import in health_pb2_grpc.py - it imports health_pb2 without proto. prefix
# We need to change it to import proto.health_pb2
RUN sed -i 's/^import health_pb2 as health__pb2$/import proto.health_pb2 as health__pb2/' proto/health_pb2_grpc.py || true
RUN sed -i 's/^from health_pb2/from proto.health_pb2/' proto/health_pb2_grpc.py || true

# Copy application code (server + AI model service)
COPY server.py .
COPY services/ services/

# Create proto/__init__.py if it doesn't exist (allows proto to be imported as package)
RUN touch proto/__init__.py || true

# Make server.py executable
RUN chmod +x server.py

# Expose gRPC port (default 50051)
EXPOSE 50051

# Set default environment variables
ENV PORT=50051

# Run the server
# Use python -m to run as module, which ensures proper path handling
CMD ["python", "-m", "server"]
